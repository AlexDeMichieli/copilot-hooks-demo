#!/usr/bin/env bash
# preToolUse hook - enforces guardrails before any tool executes
#
# This is one of four GitHub Copilot coding agent hooks:
# - sessionStart: runs once when agent session begins
# - preToolUse: runs before each tool call (can deny)
# - postToolUse: runs after each tool call (audit/logging)
# - sessionEnd: runs when session completes
#
# Full docs: https://docs.github.com/en/copilot/customizing-copilot/using-copilot-coding-agent/customizing-the-coding-agent-with-hooks

INPUT=$(cat)
TOOL_NAME=$(echo "$INPUT" | jq -r '.toolName')
TOOL_ARGS=$(echo "$INPUT" | jq -r '.toolArgs')

# Helper to deny a tool call
deny() {
  jq -n --arg reason "$1" '{
    "permissionDecision": "deny",
    "permissionDecisionReason": $reason
  }'
  exit 0
}

# Rule 1: Only allow file edits in src/
if [[ "$TOOL_NAME" == "edit" ]] || [[ "$TOOL_NAME" == "create" ]]; then
  FILE_PATH=$(echo "$TOOL_ARGS" | jq -r '.path // .filePath // empty')
  
  if [[ ! "$FILE_PATH" =~ ^src/ ]]; then
    deny "File edits restricted to src/ directory. Attempted: $FILE_PATH"
  fi
  
  # Rule 3: Block hardcoded secrets
  CONTENT=$(echo "$TOOL_ARGS" | jq -r '.content // .newContent // empty')
  if echo "$CONTENT" | grep -qiE '(api[_-]?key|password|secret|token)\s*[:=]\s*["\x27][a-zA-Z0-9_-]{10,}'; then
    deny "Hardcoded secret detected. Use environment variables."
  fi
fi

# Rule 2: Block dependency installation
if [[ "$TOOL_NAME" == "bash" ]]; then
  COMMAND=$(echo "$TOOL_ARGS" | jq -r '.command // empty')
  
  if echo "$COMMAND" | grep -qE '(pip|npm|yarn) install'; then
    deny "Dependency installation not permitted. Blocked: $COMMAND"
  fi
fi

# Allow if no rules triggered
jq -n '{"permissionDecision": "allow"}'
